# Copy to .env.local (do not commit real tokens to .env.example).

# Option A — all Next vars here (typical for deploy)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_READ_TOKEN=

# Option B — project/dataset can live only in ../studio/.env as SANITY_STUDIO_*;
# next.config loads that file. You still need SANITY_API_READ_TOKEN here or in studio/.env.

NEXT_PUBLIC_SANITY_STUDIO_URL=http://localhost:3333
